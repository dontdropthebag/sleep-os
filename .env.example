# ─────────────────────────────────────────────────────────────
# Sleep Intelligence OS — example environment (NO real secrets here)
# Copy to `.env` for local dev. In production set these in your host's
# dashboard (Vercel / Render / Railway), never commit real values.
# ─────────────────────────────────────────────────────────────

# ── Backend (FastAPI) ──
# Database. Local dev defaults to SQLite automatically (no value needed).
# In production use a hosted Postgres. Providers' postgres:// URLs are
# auto-normalized to the psycopg driver. The app also reads a plain
# DATABASE_URL (what most providers inject), so the SIOS_ prefix is optional.
# SIOS_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Allowed browser origin(s) for CORS — set to your deployed frontend URL.
# Comma-separate multiple origins.
SIOS_CORS_ORIGINS=http://localhost:3000
# Optional regex to allow dynamic origins (e.g. Vercel preview deployments):
# SIOS_CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Upload safety cap (bytes). Default 200 MB.
SIOS_MAX_UPLOAD_BYTES=209715200
# Raw sleep audio is discarded after analysis unless explicitly retained.
SIOS_RETAIN_RAW_AUDIO=false

# ── Frontend (Next.js) ──
# Public base URL of the backend API (baked into the browser bundle — not a
# secret). Local dev default is http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
